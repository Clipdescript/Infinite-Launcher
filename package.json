{
  "name": "infinite-launcher",
  "version": "2.0.7",
  "description": "Infinite Launcher - Launcher Minecraft Moderne",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "start": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "lint": "tsc --noEmit && eslint src electron --ext .ts,.tsx"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-virtual": "^3.13.24",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.3.0",
    "firebase": "^12.13.0",
    "jsdom": "^29.1.1",
    "kokoro-js": "^1.2.1",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "onnxruntime-node": "^1.26.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.infinite-launcher.app",
    "productName": "Infinite Launcher",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/main.js",
      "dist-electron/main.js.map",
      "dist-electron/preload.cjs",
      "dist-electron/preload.cjs.map",
      "dist-electron/GameManager.js",
      "dist-electron/GameManager.js.map",
      "Infinite.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "Infinite.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Infinite Launcher"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Clipdescript",
        "repo": "Infinite-Launcher"
      }
    ]
  }
}
